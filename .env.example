# Default configuration values live in seneschal.pro.toml (PRO) or seneschal.dev.toml (DEV).
# The file is selected by SENECHAL_ENV (default: pro).
# Environment variables override the selected config file's values.
# Use SENECHAL_CONFIG_FILE=/path/to/custom.toml to load an alternate config file (highest precedence).

# ── Environment ──────────────────────────────────────────────────────────────
# SENECHAL_ENV=pro                # Environment: "pro" (default, production) or "dev" (development)
# Determines which config file is loaded (seneschal.pro.toml / seneschal.dev.toml)
# and which data directory is used (data/pro/ / data/dev/).
# SENECHAL_CONFIG_FILE still takes highest precedence if set.

# ── Audio Input ───────────────────────────────────────────────────────────────
AUDIO_SAMPLE_RATE=16000          # Microphone sample rate in Hz (Silero VAD requires 16000)
AUDIO_CHANNELS=1                 # Number of audio input channels (1 = mono)
AUDIO_CHUNK_MS=100               # Size of each audio processing chunk in milliseconds
AUDIO_INPUT_DEVICE=MacBook Pro   # Substring match of input device name; unset = system default
AUDIO_OUTPUT_DEVICE=MacBook Pro  # Substring match of output device name; unset = system default

# ── VAD (Voice Activity Detection) ───────────────────────────────────────────
VAD_SILENCE_MS=200               # Milliseconds of silence before SpeechEnd fires (lower = faster response, higher = fewer mid-sentence cuts)
VAD_START_THRESHOLD=0.65         # Hysteresis: threshold to start speech (silence -> speech)
VAD_END_THRESHOLD=0.45           # Hysteresis: threshold to keep speech active (speech -> silence below this)
VAD_MODEL=models/ggml-silero-vad.bin  # Path to Silero VAD model file (.bin) used by whisper-cpp-plus

# ── Language ──────────────────────────────────────────────────────────────────
SENECHAL_LANGUAGE=en             # Transcription and voice language: "en" (English, default) or "es" (Spanish)

# ── STT (Speech-to-Text) ──────────────────────────────────────────────────────
# STT provider selection. "speech" (default on macOS, SFSpeechRecognizer), "whisper" (whisper-cpp-plus), or "parakeet" (NVIDIA Parakeet via ONNX, --features parakeet)
# Parakeet supports 25 languages offline via ParakeetTDT batch model. Both providers share the same Silero VAD.
STT_PROVIDER=speech

## Whisper provider (default, no extra features needed)
WHISPER_MODEL=models/ggml-large-v3-turbo.bin  # Path to whisper.cpp GGML model file (.bin)
WHISPER_THREADS=0                   # Number of CPU threads for Whisper decoding (0 = auto-detect)
WHISPER_COREML=1                    # Enable CoreML/Metal GPU acceleration on macOS
WHISPER_SILENCE=1                   # Suppress verbose whisper.cpp logs (Metal/GPU init messages via printf). Set to "1", "true", or "yes" to silence. Use WHISPER_VERBOSE=1 to override if needed.

## Parakeet provider (requires: cargo build --features parakeet)
# Path to the Parakeet ONNX model directory. Must contain ONNX Runtime files:
#   encoder-model.onnx, decoder_joint-model.onnx, vocab.txt
# Download the ONNX export from: https://huggingface.co/istupakov/parakeet-tdt-0.6b-v3-onnx
# PARAKEET_MODEL_DIR=models/parakeet-tdt-0.6b-v3-onnx

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_URL=http://localhost:8000       # Base URL of the LLM server (OpenAI-compatible, e.g. mlx-lm default port 8000 or omlx default port 8001)
LLM_API_KEY=sk-...                  # API key sent as "Authorization: Bearer <key>"; leave unset for local servers with no auth
LLM_MODEL=local-model               # Model name sent in the "model" field of API requests
LLM_MAX_TOKENS=400                  # Maximum number of tokens per LLM response
LLM_TEMPERATURE=0.7                 # Sampling temperature for LLM responses (higher = more creative)
LLM_SYSTEM_PROMPT=Eres un asistente...  # System prompt injected as the first message of every conversation
NOOP_TOOL_INSTRUCTIONS=Call the noop tool when the user asks something to Siri or Alexa, or requests another assistant. The noop tool stops the current query without any response.
LLM_CONTEXT_TOKENS=32536            # Approximate context window of the LLM model in tokens; summarization triggers at 75% of this limit
LLM_SUMMARY_KEEP_TURNS=6            # Number of most-recent conversation turns to keep verbatim after summarization
LLM_IDLE_CONSOLIDATION_SECS=1800    # Seconds of user inactivity before a silent consolidation runs (0 = disabled). |
LLM_CONSOLIDATION_THRESHOLD_PCT=90  # Percentage of context window that triggers memory consolidation (see below).
LLM_IDLE_MIN_CONTEXT_PCT=50         # Context fill % threshold used by idle-triggered consolidation. Consolidates proactively while idle to stay below the hard limit (0 = disabled). 

# ── TTS (Text-to-Speech) ──────────────────────────────────────────────────────
TTS_PROVIDER=say                 # TTS backend: "say" (macOS say, default), "avspeech" (AVSpeechSynthesizer, --features avspeech), or "kokoro" (--features kokoro)

## macOS `say` backend
SAY_VOICE=Marisol (Enhanced)     # macOS voice name used by `say`; list available voices with: say -v ?
SAY_RATE=215                     # Speaking rate in words per minute for `say`

## AVSpeechSynthesizer backend (--features avspeech)
AVSPEECH_VOICE=Jorge (Enhanced)  # AVSpeechSynthesizer voice display name; list voices with: say -v ?
AVSPEECH_RATE=0.55               # Normalized speech rate 0.0–1.0 (0.5 ≈ 180 wpm, 0.55 ≈ 215 wpm)

## Kokoro backend (--features kokoro)
KOKORO_MODEL=models/kokoro-v1.0.onnx   # Path to the kokoro-v1.0.onnx ONNX model file
KOKORO_VOICES=models/voices-v1.0.bin   # Path to the voices-v1.0.bin voice embeddings file
KOKORO_VOICE=af_bella                  # Kokoro voice style name (e.g. "af_bella", "es_*")
KOKORO_LANGUAGE=en-us                  # BCP-47 language code for espeak-ng phonemization (e.g. "en-us", "es")

# ── Agent Delegation (Multi-Agent Registry) ───────────────────────────────────
# Comma-separated list of agent names to enable. Each agent gets its own tool
# (run_<name>) and appears in the system prompt with when-to-use guidance.
# If AGENTS is unset but legacy AGENT_COMMAND/AGENT_MODE are set, a single
# "hermes" agent is auto-created for backward compatibility.
AGENTS=hermes

# Per-agent configuration (replace <NAME> with the agent name, uppercase):
AGENT_<NAME>_MODE=acp|cli              # Communication mode (default: acp)
AGENT_<NAME>_COMMAND=...               # CLI command (mode=cli only)
AGENT_<NAME>_ACP_COMMAND=...           # ACP command (mode=acp only)
AGENT_<NAME>_ACP_WARMUP=0|1            # Pre-warm ACP session at startup
AGENT_<NAME>_WHEN_TO_USE="..."         # LLM-facing: when to delegate to this agent
AGENT_<NAME>_INSTRUCTIONS="..."        # Agent-facing: behavioral instructions

# ── Hermes (default) ─────────────────────────────────────────────────────────
AGENT_HERMES_MODE=acp
AGENT_HERMES_ACP_COMMAND=hermes acp
AGENT_HERMES_ACP_WARMUP=0
AGENT_HERMES_WHEN_TO_USE="Tareas generales de investigación, búsqueda web, gestión de calendario, y tareas que requieren razonamiento extendido con acceso a herramientas del sistema."
AGENT_HERMES_INSTRUCTIONS="Eres Hermes, un agente experto y ultra-eficiente. Tienes acceso a herramientas de computadora, archivos, web, calendario y razonamiento extendido. Resuelve la tarea de forma autónoma y devuelve un resultado conciso y accionable."

# ── Legacy Agent Config (backward compat — use AGENTS format above instead) ───
# AGENT_COMMAND=hermes chat            # CLI command; unset = agent tools disabled
# AGENT_TIMEOUT_SECS=120               # Hard timeout for agent calls
# AGENT_MODE=cli                       # "cli" or "acp"
# AGENT_ACP_COMMAND=hermes acp         # ACP command (mode=acp only)
# AGENT_ACP_WARMUP=0                   # Pre-warm at startup
# AGENT_PROMPT_INSTRUCTIONS="..."      # Agent-facing instructions

# ── MCP (Model Context Protocol) ──────────────────────────────────────────────
# Multi-MCP format: list server names in MCPS, then configure each with MCP_<NAME>_COMMAND.
# Tool names are prefixed as {name}_mcp__{tool_name} to avoid collisions between servers.
# MCPS=apple,filesystem                # Comma-separated list of server names
# MCP_APPLE_COMMAND=bunx apple-mcp@latest
# MCP_APPLE_TIMEOUT_SECS=300           # Per-server timeout (default: 30s)
# MCP_FILESYSTEM_COMMAND=npx -y @modelcontextprotocol/server-filesystem /tmp
# MCP_FILESYSTEM_TIMEOUT_SECS=60
#
# Legacy single-MCP format (backward compatible — produces tools named "default_mcp__..."):
# MCP_COMMAND=bunx apple-mcp@latest
# MCP_TOOL_TIMEOUT_SECS=300

# ── ACP Log Viewer ─────────────────────────────────────────────────────────────
# Log all JSON-RPC ACP traffic to a file and auto-open a Terminal tail.
# Modes: off (default) | logfile
HERMES_SESSION_VIEWER=off

# ── Inference Daemon ──────────────────────────────────────────────────────────
DAEMON_ENABLED=0                  # Set to 1 or true to enable the background "is there anything worth saying?" loop
DAEMON_INTERVAL_SECS=1800         # Seconds between daemon proactive-check cycles

# ── Shell Tool ────────────────────────────────────────────────────────────────
SHELL_ENABLED=0                   # Set to 1 or true to enable the run_shell tool (off by default for safety)
SHELL_TIMEOUT_SECS=30             # Hard timeout per shell command in seconds

# ── Web Search (Native API Providers — Fast Path) ──────────────────────────────
# Native providers are preferred because they add ~1-3s latency vs 10-30s for
# agent delegation.  Set one API key to enable `quick_search`:
#   TAVILY_API_KEY  (recommended — purpose-built for LLMs)
#   EXA_API_KEY     (alternative — semantic search engine)
# TAVILY_MAX_TOKENS=512               # Tavily AI answer max tokens (0 = disabled)

# ── Web Search (SearXNG Fallback) ──────────────────────────────────────────────
# SEARXNG_URL=http://tesla.local:8080  # Base URL of SearXNG instance; used as fallback
# SEARXNG_SECRET=                       # Bearer token for SearXNG API authentication

# ── Speaker Verification ──────────────────────────────────────────────────────
SPEAKER_MODEL=models/speaker_embedding.onnx  # Path to sherpa-onnx speaker embedding ONNX model; auto-detected from models/speaker_embedding.onnx if present, disabled if absent
SPEAKER_ENROLLMENT_PATH=data/speaker.emb     # Path where the enrolled speaker embedding is persisted (default via config: data/{env}/speaker.emb)
SPEAKER_SIMILARITY_MIN=0.45                  # Cosine similarity threshold [0.0–1.0] for speaker verification (higher = stricter)
SPEAKER_AMBIENT_TRIGGER=3                    # Consecutive non-enrolled-speaker VAD segments before auto-switching to Ambient mode (requires speaker verification enabled)

# ── Conversation Mode ─────────────────────────────────────────────────────────
WAKE_WORD=seneschal                    # Wake word that triggers a response in Ambient mode (case-insensitive substring match)
AMBIENT_CLEAR_SECS=300              # Seconds in Ambient mode with no speech before auto-returning to Active mode

# ── Persistence ───────────────────────────────────────────────────────────────
DB_PATH=data/seneschal.db            # Path to the SQLite database file for chat history persistence (default via config: data/{env}/seneschal.db)

# ── Secondary LLM ─────────────────────────────────────────────────────────────
SECONDARY_LLM_URL=                  # Base URL of secondary LLM. Enables `take_screenshot` tool, EYES visual awareness, and routes summarization + profile extraction to this model.
SECONDARY_LLM_MODEL=local-model     # Model name for secondary LLM requests.
SECONDARY_LLM_MAX_TOKENS=512        # Max tokens for secondary LLM responses (vision).
SECONDARY_LLM_API_KEY=              # Bearer token for secondary LLM API.
SECONDARY_LLM_PROVIDER=mlx          # Backend for secondary LLM (mlx-lm or omlx).

# ── Eyes ──────────────────────────────────────────────────────────────────────
EYES_INTERVAL_SECS=0                # Seconds between automatic screen captures. Set to e.g. `15`, to enable. Set `0` to disabled. Requires `SECONDARY_LLM_URL` (vision model). The bot speaks when something important is detected on screen.
# ── Cold Path Memory (S-DREAM) ─────────────────────────────────────────────────
# S-DREAM is a background consolidation system for long-term memory archival.
# It runs periodically, on idle, or at a scheduled daily hour to consolidate
# older conversation messages into compressed JSONL archives.
S_DREAM_INTERVAL_SECS=3600            # Seconds between periodic consolidation cycles (0 = disabled; default 3600 = 1h)
S_DREAM_ON_IDLE=1                     # Trigger consolidation when user is idle (1 = true, 0 = false; default 1)
S_DREAM_IDLE_THRESHOLD_SECS=600       # Seconds of user inactivity before idle consolidation triggers (default 600 = 10min)
S_DREAM_SCHEDULED_HOUR=3              # Scheduled hour (0-23) for daily consolidation; set empty to disable (default 3 = 3 AM)
S_DREAM_L2_MIN_MESSAGES=50            # Minimum number of L2 messages before consolidation triggers (default 50)
S_DREAM_JSONL_DIR=data/archives       # Directory for archived JSONL consolidation files (default: data/{env}/archives)

# ── CoreML / ANE Acceleration (macOS only) ─────────────────────────────────────
# Enable Apple Neural Engine for faster encoding (requires rebuild):
# WHISPER_USE_COREML=1                    # Set this BEFORE building
# 
# To enable CoreML:
# 1. Ensure you have <model>-encoder.mlmodelc in models directory
# 2. Run: cargo clean -p whisper-cpp-plus-sys
# 3. Run: WHISPER_USE_COREML=1 cargo build --release
#
# Your setup already has ggml-large-v3-turbo-encoder.mlmodelc ✓
